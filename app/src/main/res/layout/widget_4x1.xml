<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_bg_rounded"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- Emoji -->
    <TextView
        android:id="@+id/tv_widget_emoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎉"
        android:textSize="28sp"
        android:paddingEnd="10dp" />

    <!-- Event Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_widget_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="圣诞节"
            android:textColor="#FFFFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026年12月25日 星期五"
            android:textColor="#CCFFFFFF"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Days Count -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_widget_days"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="128"
                android:textColor="#FFFFFFFF"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_widget_days_unit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="天"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:paddingTop="14sp" />
        </LinearLayout>

        <!-- 刷新按钮 -->
        <ImageView
            android:id="@+id/btn_widget_refresh"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_popup_sync"
            android:tint="#AAFFFFFF"
            android:contentDescription="刷新" />
    </LinearLayout>
</LinearLayout>
